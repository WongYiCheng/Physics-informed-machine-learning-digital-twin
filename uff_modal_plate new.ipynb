  {
   "cell_type": "code",
   "execution_count": 129,
   "metadata": {},
   "outputs": [],
   "source": [
    "dataset164 = pyuff.prepare_164(\n",
    "    units_code=1,\n",
    "    units_description='SI units',\n",
    "    temp_mode=1,\n",
    "    length=1.0,\n",
    "    force=1.0,\n",
    "    temp=1.0,\n",
    "    temp_offset=1.0)\n",
    "\n",
    "if save_to_file:\n",
    "    if os.path.exists(save_to_file):\n",
    "        os.remove(save_to_file)\n",
    "    uffwrite = pyuff.UFF(save_to_file)\n",
    "    uffwrite._write_set(dataset164, 'add')"
   ]
  },
