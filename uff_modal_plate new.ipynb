    "import numpy as np\n",
    "import pyuff\n",
    "import os\n",

    "# In this file, cell 3,4,5 is being commented as it is originally to treat csv data, this file convert frf data to unv file for ANSYS. (input data will be 60,9,2049) where first trial is taken and 9 sensors used
    "# save_to_file = '../unv_file/MAC_UD_T35_R1.unv' ../mean find one level up\n",
    "class_name = 'HD_E4'\n",
    "save_to_file = f'unv_file3/MAC_{class_name}_Group.unv'\n",
    "\n",
    "modalparameters = np.load(f'Modal Parameter Extracted NPY3\\\\Modalparameters_(T){class_name}_T00_R3.npy')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Dataset 164"
