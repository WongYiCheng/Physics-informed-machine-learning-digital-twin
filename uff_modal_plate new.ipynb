    "# 1. Manually define the data you extracted from the end result\n",
    "# Columns: [Node_ID, X, Y, Z]\n",
    "data = np.array([\n",
    "    [1, -0.18400,  0.08000, 0.00000],\n",
    "    [2, -0.18400,  0.00000, 0.00000],\n",
    "    [3, -0.18400, -0.08000, 0.00000],\n",
    "    [4,  0.00000,  0.08000, 0.00000],\n",
    "    [5,  0.00000,  0.00000, 0.00000],\n",
    "    [6,  0.00000, -0.08000, 0.00000],\n",
    "    [7,  0.18400,  0.08000, 0.00000],\n",
    "    [8,  0.18400,  0.00000, 0.00000],\n",
    "    [9,  0.18400, -0.08000, 0.00000]\n",
    "])\n",
    "\n",
    "# 2. Prepare Dataset 15\n",
    "dataset15 = pyuff.prepare_15(\n",
    "    node_nums = data[:, 0].astype(int), # Node IDs (1 to 9)\n",
    "    x = data[:, 1],                    # X coordinates\n",
    "    y = data[:, 2],                    # Y coordinates\n",
    "    z = data[:, 3],                    # Z coordinates\n",
    "    def_cs = None,                     # Definition Coordinate System (usually 0)\n",
    "    disp_cs = None,     # Displacement Coordinate System (usually 0)\n",
    "    color = None        # Node color (usually 0)\n",
    ")\n",
    "\n",
    "# 3. Write to your UNV file\n",
    "# Assuming 'uffwrite' was defined earlier in your script\n",
    "uffwrite._write_set(dataset15, 'add')\n",
    "\n",
    "print(\"Successfully wrote 9 nodes to the UNV file.\")"
   ]
  },
