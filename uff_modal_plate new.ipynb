    "# Dataset 82"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 134,
   "metadata": {},
   "outputs": [],
   "source": [
    "tracenumbers = np.arange(1,4)\n",
    "number_nodes = np.array([9, 3, 3])\n",
    "nodes_array = [[1,4,7,8,9,6,3,2,1], [2,5,8], [4,5,6]]\n",
    "uff_datasets_82 = []\n",
    "\n",
    "for i in range(len(tracenumbers)):\n",
    "    dataset82 = pyuff.prepare_82(\n",
    "        trace_num=tracenumbers[i],\n",
    "        n_nodes=number_nodes[i],\n",
    "        color=30,\n",
    "        id=f'Trace Line {tracenumbers[i]}',\n",
    "        nodes=np.array(nodes_array[i]))\n",
    "    uff_datasets_82.append(dataset82.copy())\n",
    "    \n",
    "    uffwrite._write_set(dataset82, 'add')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Dataset 55"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 135,
   "metadata": {},
   "outputs": [],
   "source": [
    "# modalparameters = np.load(f'Modal Parameter Extracted NPY_2\\\\Modalparameters_(N)HD_E1_T00_R1.npy')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 136,
   "metadata": {},
   "outputs": [],
   "source": [
    "class Mode:\n",
    "    def __init__(self, mp, mode, shift_phase):\n",
    "        self.omega_damped = mp[mode-1, 0]*2*np.pi\n",
    "        self.damping_ratio = mp[mode-1, 1]\n",
    "        self.omega_natural = self.omega_damped / (1 - self.damping_ratio**2)**0.5\n",
    "        # self.eigenvalue = 1j*self.omega_damped - (self.damping_ratio*self.omega_damped/(1 - self.damping_ratio**2)**0.5)\n",
    "        self.eigenvalue = - (self.damping_ratio * self.omega_natural) + 1j * self.omega_natural\n",
    "        self.accX_complex = np.full(len(data), 0+0j) # must be complex number, else cannot be written to UFF properly\n",
    "        self.accY_complex = np.full(len(data), 0+0j) # must be complex number, else cannot be written to UFF properly\n",
    "        \n",
    "        if shift_phase:\n",
    "            max_abs_index = np.argmax(np.abs(mp[mode-1, 2:]))\n",
    "            phase_subtract = np.angle(mp[mode-1, 2:][max_abs_index])\n",
    "            self.accZ_complex = mp[mode-1, 2:] * 9.80665 * np.exp(-1j*phase_subtract) # convert from g to m/s2\n",
    "        else:\n",
    "            self.accZ_complex = mp[mode-1, 2:] * 9.80665 # convert from g to m/s2\n",
    "\n",
    "num_nodes = len(data)\n",
    "mode1 = Mode(modalparameters, 1, 1)\n",
    "mode2 = Mode(modalparameters, 2, 1)\n",
    "mode3 = Mode(modalparameters, 3, 1)\n",
    "\n",
    "modes = [mode1, mode2, mode3]\n",
    "\n",
    "#node_numbs = np.arange(1,len(coordinates.index)+1)\n",
    "node_numbs = np.arange(1, num_nodes + 1)\n",
    "mode_number = 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 137,
   "metadata": {},
   "outputs": [],
   "source": [
    "uff_datasets_55 = []\n",
    "\n",
    "# warnings for r1,r2,r3,eig dtypes are suppressed in library\n",
    "\n",
    "for mode in modes:\n",
    "    \n",
    "    dataset55 = pyuff.prepare_55(\n",
    "        model_type=1,\n",
    "        data_type=5,\n",
    "        id1='NONE',\n",
    "        id2='NONE',\n",
    "        id3='NONE',\n",
    "        id4='NONE',\n",
    "        id5='NONE',\n",
    "        analysis_type=3,\n",
    "        data_ch=2,\n",
    "        spec_data_type=12,\n",
    "        r1=np.array(mode.accX_complex),\n",
    "        r2=np.array(mode.accY_complex),\n",
    "        r3=np.array(mode.accZ_complex),\n",
    "        n_data_per_node=3,\n",
    "        node_nums=node_numbs,\n",
    "        load_case=0,\n",
    "        eig=mode.eigenvalue,\n",
    "        mode_n=int(mode_number),\n",
    "        )\n",
    "    uff_datasets_55.append(dataset55.copy())\n",
    "    \n",
    "    uffwrite._write_set(dataset55, 'add')\n",
    "    mode_number += 1"
   ]
  }
